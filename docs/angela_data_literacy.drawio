        <mxCell id="t3_center" value="&lt;b style=&quot;font-size:14px&quot;&gt;&amp;#x267B;&amp;#xFE0F; Continuous&lt;br&gt;Improvement&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;Daemon runs every 4h&lt;br&gt;~$0.30/day total&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=#FFFBEB;strokeColor=#FDE68A;rounded=1;fontSize=11;" vertex="1" parent="1">
