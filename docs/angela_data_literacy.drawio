        <mxCell id="t3_s2" value="&lt;b&gt;2. PREDICT&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot; color=&quot;#6B7280&quot;&gt;PredictiveCompanion&lt;/font&gt;&lt;hr size=&quot;1&quot;&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Reads: companion_patterns, conversations&lt;br&gt;Writes: daily_companion_briefings (10)&lt;br&gt;&lt;font color=&quot;#DC2626&quot;&gt;LLM: Ollama&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;spacingTop=3;spacingLeft=6;spacingRight=6;fillColor=#D1FAE5;strokeColor=#34D399;" vertex="1" parent="1">
