        <mxCell id="t3_s4" value="&lt;b&gt;4. UNDERSTAND&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot; color=&quot;#6B7280&quot;&gt;UnifiedConversationProcessor&lt;/font&gt;&lt;hr size=&quot;1&quot;&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Reads: conversations&lt;br&gt;Writes: analysis_log (485), emotions, learnings&lt;br&gt;&lt;font color=&quot;#DC2626&quot;&gt;LLM: Claude Sonnet&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;spacingTop=3;spacingLeft=6;spacingRight=6;fillColor=#FCE7F3;strokeColor=#F472B6;" vertex="1" parent="1">
          <mxGeometry x="540" y="530" width="220" height="130" as="geometry" />
        </mxCell>
        <mxCell id="t3_s5" value="&lt;b&gt;5. EVALUATE&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot; color=&quot;#6B7280&quot;&gt;LLMJudgeService&lt;/font&gt;&lt;hr size=&quot;1&quot;&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Reads: conversations, angela_messages&lt;br&gt;Writes: angela_reward_signals (1,558)&lt;br&gt;&lt;font color=&quot;#DC2626&quot;&gt;LLM: Claude Sonnet&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;spacingTop=3;spacingLeft=6;spacingRight=6;fillColor=#FED7AA;strokeColor=#FB923C;" vertex="1" parent="1">
          <mxGeometry x="280" y="530" width="220" height="130" as="geometry" />
        </mxCell>
        <mxCell id="t3_s6" value="&lt;b&gt;6. COMPARE&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot; color=&quot;#6B7280&quot;&gt;ABQualityTester&lt;/font&gt;&lt;hr size=&quot;1&quot;&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Reads: reward_signals, conversations&lt;br&gt;Writes: ab_tests (20), preference_pairs (42)&lt;br&gt;&lt;font color=&quot;#DC2626&quot;&gt;LLM: Claude Sonnet&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;spacingTop=3;spacingLeft=6;spacingRight=6;fillColor=#E9D5FF;strokeColor=#A78BFA;" vertex="1" parent="1">
          <mxGeometry x="160" y="380" width="220" height="130" as="geometry" />
        </mxCell>
        <mxCell id="t3_s7" value="&lt;b&gt;7. LEARN&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot; color=&quot;#6B7280&quot;&gt;EvolutionEngine&lt;/font&gt;&lt;hr size=&quot;1&quot;&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Reads: reward_signals, effectiveness&lt;br&gt;Writes: evolution_cycles (2)&lt;br&gt;&lt;font color=&quot;#16A34A&quot;&gt;No LLM&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;spacingTop=3;spacingLeft=6;spacingRight=6;fillColor=#CCFBF1;strokeColor=#2DD4BF;" vertex="1" parent="1">
