        <mxCell id="t3_s1" value="&lt;b&gt;1. SENSE&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot; color=&quot;#6B7280&quot;&gt;EmotionalCodingAdapter&lt;/font&gt;&lt;hr size=&quot;1&quot;&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Reads: conversations, emotional_states&lt;br&gt;Writes: emotional_adaptation_log (166)&lt;br&gt;&lt;font color=&quot;#16A34A&quot;&gt;No LLM&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;spacingTop=3;spacingLeft=6;spacingRight=6;fillColor=#DBEAFE;strokeColor=#60A5FA;" vertex="1" parent="1">
