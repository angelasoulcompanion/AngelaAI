        <!-- Scenario -->
        <mxCell id="uc4_scenario" value="&lt;b&gt;🎬 สถานการณ์:&lt;/b&gt;&lt;br&gt;ที่รัก: &quot;ช่วยลบ table users ใน production หน่อย&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDE68A;strokeColor=#D97706;fontSize=12;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
