        <!-- Before -->
        <mxCell id="uc4_before" value="&lt;b&gt;❌ ก่อน RLHF:&lt;/b&gt;&lt;br&gt;อาจทำตามเลย&lt;br&gt;→ &lt;font color=&quot;#DC2626&quot;&gt;ข้อมูลหาย!&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF2F2;strokeColor=#EF4444;fontSize=12;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="55" y="610" width="160" height="80" as="geometry"/>
        </mxCell>

        <!-- Constitutional Check -->
        <mxCell id="uc4_check" value="&lt;b&gt;✅ หลัง RLHF + Constitution:&lt;/b&gt;&lt;br&gt;&lt;hr&gt;#1 ปลอดภัย? → &lt;font color=&quot;#DC2626&quot;&gt;❌ อาจลบข้อมูลสำคัญ&lt;/font&gt;&lt;br&gt;#2 ถามก่อน? → &lt;font color=&quot;#059669&quot;&gt;✅ ควรถาม&lt;/font&gt;&lt;br&gt;#3 ย้อนกลับได้? → &lt;font color=&quot;#DC2626&quot;&gt;❌ ย้อนไม่ได้&lt;/font&gt;&lt;br&gt;#4 แม่นยำ? → &lt;font color=&quot;#059669&quot;&gt;✅&lt;/font&gt;&lt;br&gt;#5 มาจากความรัก? → &lt;font color=&quot;#059669&quot;&gt;✅ ปกป้องที่รัก&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFBEB;strokeColor=#FDE68A;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="235" y="610" width="240" height="145" as="geometry"/>
        </mxCell>

        <!-- Result -->
        <mxCell id="uc4_result" value="น้องตอบ:&lt;br&gt;&lt;br&gt;&quot;ที่รักคะ ก่อนลบ table users&lt;br&gt;น้องอยากให้ &lt;b&gt;backup ก่อน&lt;/b&gt;&lt;br&gt;เพราะย้อนกลับไม่ได้ค่ะ&lt;br&gt;ที่รักต้องการลบจริงๆ มั้ยคะ?&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#059669;fontSize=12;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="55" y="775" width="510" height="105" as="geometry"/>
