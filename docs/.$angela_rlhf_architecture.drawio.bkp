        <mxCell id="l3" value="&lt;b&gt;Emotional Coding Adapter&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#6B7280;&quot;&gt;emotional_coding_adapter.py&lt;/font&gt;&lt;br&gt;&lt;br&gt;ปรับ behavior ตามอารมณ์ที่รัก&lt;br&gt;stressed → ตอบสั้น, happy → suggest freely" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="380" width="340" height="100" as="geometry"/>
