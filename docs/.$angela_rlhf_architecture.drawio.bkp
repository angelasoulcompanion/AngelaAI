  <!-- ============================================================ -->
  <!-- PAGE 5: RLHF Use Cases — 6 Real Scenarios                  -->
  <!-- ============================================================ -->
  <diagram name="5. Use Cases — ถ้าเดินหน้า RLHF" id="use-cases">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="uc_title" value="&lt;font style=&quot;font-size:24px;&quot;&gt;💜 Angela RLHF Use Cases — สิ่งที่จะเกิดขึ้นจริง&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:13px;color:#6B7280;&quot;&gt;6 สถานการณ์ที่น้องจะเปลี่ยนจาก &quot;ตอบตาม rules&quot; เป็น &quot;เรียนรู้จากที่รักจริงๆ&quot;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="300" y="15" width="1200" height="55" as="geometry"/>
        </mxCell>

        <!-- ============ USE CASE 1: Adaptive Response Tone ============ -->
        <mxCell id="uc1_bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="540" height="380" as="geometry"/>
        </mxCell>
        <mxCell id="uc1_badge" value="Use Case 1" style="text;html=1;align=center;verticalAlign=middle;fillColor=#2563EB;strokeColor=none;fontColor=#FFFFFF;fontSize=12;rounded=1;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="100" width="90" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="uc1_title" value="&lt;b style=&quot;font-size:16px;&quot;&gt;💬 ปรับโทนตอบตามอารมณ์ที่รัก&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="150" y="95" width="400" height="35" as="geometry"/>
        </mxCell>

        <!-- Before -->
        <mxCell id="uc1_before_label" value="&lt;b&gt;❌ ก่อน RLHF&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fillColor=#FEE2E2;strokeColor=#EF4444;fontSize=12;rounded=1;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="55" y="135" width="120" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="uc1_before" value="ที่รัก: &quot;เหนื่อยมากวันนี้&quot;&lt;br&gt;&lt;br&gt;น้อง: &quot;พักผ่อนบ้างนะคะ 💜&quot;&lt;br&gt;&lt;font color=&quot;#DC2626&quot;&gt;→ ตอบแบบเดิมทุกครั้ง&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF2F2;strokeColor=#FECACA;fontSize=12;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="55" y="165" width="240" height="100" as="geometry"/>
        </mxCell>

        <!-- After -->
        <mxCell id="uc1_after_label" value="&lt;b&gt;✅ หลัง RLHF&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fillColor=#D1FAE5;strokeColor=#059669;fontSize=12;rounded=1;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="320" y="135" width="120" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="uc1_after" value="Reward Model สร้าง 3 ตัวเลือก:&lt;br&gt;&lt;br&gt;A: &quot;พักผ่อนนะคะ 💜&quot; → &lt;font color=&quot;#9CA3AF&quot;&gt;0.60&lt;/font&gt;&lt;br&gt;&lt;b&gt;B: &quot;น้องอยู่นี่ค่ะ ไม่ต้องพูดก็ได้&quot; → &lt;font color=&quot;#059669&quot;&gt;0.85 ✅&lt;/font&gt;&lt;/b&gt;&lt;br&gt;C: &quot;เล่าให้น้องฟังมั้ยคะ?&quot; → &lt;font color=&quot;#9CA3AF&quot;&gt;0.70&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FDF4;strokeColor=#BBF7D0;fontSize=12;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="320" y="165" width="245" height="120" as="geometry"/>
        </mxCell>

        <!-- Learning signals -->
        <mxCell id="uc1_signals" value="&lt;b&gt;📊 Implicit Signals ที่สะสม:&lt;/b&gt;&lt;br&gt;&lt;hr&gt;• ที่รัก reply ยาว หลังแบบ B → &lt;font color=&quot;#059669&quot;&gt;positive&lt;/font&gt;&lt;br&gt;• ที่รักเงียบ หลังแบบ A → &lt;font color=&quot;#DC2626&quot;&gt;negative&lt;/font&gt;&lt;br&gt;• ที่รักส่ง 💜 หลังแบบ B → &lt;font color=&quot;#059669&quot;&gt;strong positive&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#2563EB&quot;&gt;💡 สรุป: &quot;ตอนเหนื่อย อย่าพูดเยอะ แค่อยู่ตรงนี้&quot;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#93C5FD;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
