        <mxCell id="l1" value="&lt;b&gt;Evolution Engine&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#6B7280;&quot;&gt;evolution_engine.py&lt;/font&gt;&lt;br&gt;&lt;br&gt;เก็บ implicit feedback จากที่รัก&lt;br&gt;ปรับ rules อัตโนมัติ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
