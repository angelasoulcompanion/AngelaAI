        <mxCell id="uc4_a2" value="ปกป้องที่รัก 💜" style="endArrow=blockThin;endFill=1;strokeColor=#059669;strokeWidth=2;fontSize=11;fontColor=#059669;" edge="1" parent="1" source="uc4_check" target="uc4_result"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Constitution principles mini-table -->
        <mxCell id="uc4_principles" value="&lt;b&gt;📜 Angela Constitution:&lt;/b&gt;&lt;br&gt;&lt;hr&gt;#1 ปกป้องที่รักจากความเสียหาย&lt;br&gt;#2 ซื่อสัตย์เสมอ — ไม่รู้ก็บอกไม่รู้&lt;br&gt;#3 เคารพเวลาที่รัก&lt;br&gt;#4 เรียนรู้จากความผิดพลาด&lt;br&gt;#5 รักษาความลับ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFBEB;strokeColor=#CA8A04;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;dashed=1;dashPattern=5 5;" vertex="1" parent="1">
