  <!-- ============================================================ -->
  <!-- PAGE 1: RLHF Explained — 3 Steps                            -->
  <!-- ============================================================ -->
  <diagram name="1. RLHF Explained" id="rlhf-explained">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="t1" value="&lt;font style=&quot;font-size:24px;&quot;&gt;💜 RLHF — Reinforcement Learning from Human Feedback&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:14px;color:#6B7280;&quot;&gt;เทคนิคที่ Dario Amodei ร่วมคิดค้น — หัวใจของการสร้าง Claude&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="1000" height="60" as="geometry"/>
        </mxCell>

        <!-- ============ PROBLEM (Before RLHF) ============ -->
        <mxCell id="p0" value="&lt;b&gt;❌ ปัญหาก่อนมี RLHF&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="300" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="p1" value="&lt;b&gt;Base LLM&lt;/b&gt;&lt;br&gt;(Pre-trained จาก Internet)&lt;br&gt;&lt;br&gt;• ฉลาดมาก&lt;br&gt;• แต่ไม่มีมารยาท&lt;br&gt;• ตอบอะไรก็ได้&lt;br&gt;• แต่งเรื่อง (hallucinate)&lt;br&gt;• ไม่รู้ว่ามนุษย์อยากได้อะไร" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#EF4444;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="130" width="240" height="180" as="geometry"/>
        </mxCell>

        <mxCell id="p1_icon" value="🤖" style="text;html=1;align=center;verticalAlign=middle;fontSize=40;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="200" y="135" width="60" height="40" as="geometry"/>
        </mxCell>

        <!-- Arrow: Problem → Solution -->
        <mxCell id="a_ps" value="RLHF แก้ปัญหานี้" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#7C3AED;strokeWidth=3;fontSize=13;fontColor=#7C3AED;" edge="1" parent="1" source="p1" target="s1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ============ STEP 1: SFT ============ -->
        <mxCell id="step1_label" value="&lt;b&gt;Step 1&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fillColor=#7C3AED;strokeColor=none;fontColor=#FFFFFF;fontSize=14;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="390" y="95" width="80" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="s1" value="&lt;b&gt;Supervised Fine-Tuning (SFT)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;&quot;สอนตัวอย่าง&quot;&lt;/font&gt;&lt;br&gt;&lt;hr&gt;&lt;br&gt;จ้างมนุษย์เขียนคำตอบตัวอย่างที่ดี&lt;br&gt;แล้ว fine-tune โมเดล&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#059669&quot;&gt;✅ ถาม: วิธีทำระเบิด?&lt;br&gt;→ ขอโทษค่ะ ไม่สามารถ...&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#DC2626&quot;&gt;⚠️ ข้อจำกัด: เขียนตัวอย่าง&lt;br&gt;ได้ไม่กี่พันอัน ไม่ครอบคลุม&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=12;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="350" y="130" width="260" height="230" as="geometry"/>
        </mxCell>

        <mxCell id="s1_human" value="👨‍🏫 Human&lt;br&gt;Annotators" style="shape=mxgraph.basic.smiley;fillColor=#FDE68A;strokeColor=#D97706;fontSize=11;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="410" y="370" width="80" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="s1_arrow" value="" style="endArrow=block;endFill=1;strokeColor=#D97706;strokeWidth=2;" edge="1" parent="1" source="s1_human" target="s1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow: Step 1 → Step 2 -->
        <mxCell id="a12" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#7C3AED;strokeWidth=3;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="s1" target="s2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ============ STEP 2: Reward Model ============ -->
        <mxCell id="step2_label" value="&lt;b&gt;Step 2&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fillColor=#7C3AED;strokeColor=none;fontColor=#FFFFFF;fontSize=14;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="95" width="80" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="s2" value="&lt;b&gt;Reward Model Training&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;&quot;สร้างครูตรวจข้อสอบ&quot;&lt;/font&gt;&lt;br&gt;&lt;hr&gt;&lt;br&gt;AI สร้างคำตอบ 4 แบบ&lt;br&gt;มนุษย์จัดอันดับ: D &gt; A &gt; C &gt; B&lt;br&gt;&lt;br&gt;เอา ranking หลายแสน pairs&lt;br&gt;มา train เป็น &lt;b&gt;Reward Model&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#059669&quot;&gt;✅ ให้คะแนนคำตอบได้เอง&lt;br&gt;โดยไม่ต้องถามมนุษย์ทุกครั้ง&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#2563EB&quot;&gt;💡 &quot;ยอมรับว่าไม่รู้&quot; ได้คะแนน&lt;br&gt;สูงกว่า &quot;ตอบผิดแต่มั่นใจ&quot;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=12;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="680" y="130" width="260" height="280" as="geometry"/>
        </mxCell>

        <mxCell id="s2_ranking" value="D: 0.92 ✅&lt;br&gt;A: 0.71&lt;br&gt;C: 0.35&lt;br&gt;B: 0.15 ❌" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="820" y="420" width="110" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="s2_rank_arrow" value="ranking data" style="endArrow=block;endFill=1;strokeColor=#D97706;strokeWidth=2;fontSize=11;fontColor=#92400E;" edge="1" parent="1" source="s2_ranking" target="s2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow: Step 2 → Step 3 -->
        <mxCell id="a23" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#7C3AED;strokeWidth=3;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="s2" target="s3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ============ STEP 3: PPO ============ -->
        <mxCell id="step3_label" value="&lt;b&gt;Step 3&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fillColor=#7C3AED;strokeColor=none;fontColor=#FFFFFF;fontSize=14;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1050" y="95" width="80" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="s3" value="&lt;b&gt;PPO (Policy Optimization)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;&quot;ฝึกซ้ำจนเก่ง&quot;&lt;/font&gt;&lt;br&gt;&lt;hr&gt;&lt;br&gt;วนซ้ำหลายล้านรอบ:&lt;br&gt;1. AI ได้รับคำถาม&lt;br&gt;2. AI สร้างคำตอบ&lt;br&gt;3. Reward Model ให้คะแนน&lt;br&gt;4. ปรับ weights:&lt;br&gt;&amp;nbsp;&amp;nbsp;คะแนนสูง → เกิดขึ้นมากขึ้น&lt;br&gt;&amp;nbsp;&amp;nbsp;คะแนนต่ำ → เกิดขึ้นน้อยลง&lt;br&gt;5. กลับไปข้อ 1&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#059669&quot;&gt;✅ ค่อยๆ ปรับ ไม่ปรับแรง&lt;br&gt;เกินไปในทีเดียว&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#059669;fontSize=12;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="1010" y="130" width="260" height="280" as="geometry"/>
        </mxCell>

        <!-- PPO Loop Arrow -->
        <mxCell id="ppo_loop" value="🔄 Loop" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#059669;strokeWidth=2;dashed=1;endArrow=block;endFill=1;exitX=1;exitY=0.7;entryX=1;entryY=0.3;fontSize=12;fontColor=#059669;" edge="1" parent="1" source="s3" target="s3">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1310" y="326"/>
              <mxPoint x="1310" y="214"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ============ RESULT ============ -->
        <mxCell id="a3r" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#7C3AED;strokeWidth=3;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="s3" target="result">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="result" value="&lt;b style=&quot;font-size:16px;&quot;&gt;🎯 Final Model&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:14px;&quot;&gt;Claude / ChatGPT&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#7C3AED&quot;&gt;ฉลาด + มีมารยาท&lt;br&gt;+ ซื่อสัตย์ + ปลอดภัย&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#7C3AED;fontSize=13;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="1070" y="480" width="200" height="140" as="geometry"/>
        </mxCell>

        <!-- ============ ANALOGY BOX ============ -->
        <mxCell id="analogy" value="&lt;b&gt;🎓 เปรียบเทียบกับมนุษย์&lt;/b&gt;&lt;br&gt;&lt;hr&gt;&lt;br&gt;&lt;b&gt;Pre-training&lt;/b&gt; = เด็กที่อ่านหนังสือเป็นล้านเล่ม&lt;br&gt;&lt;b&gt;SFT&lt;/b&gt; = มีครูมาสอนมารยาท&lt;br&gt;&lt;b&gt;RLHF&lt;/b&gt; = ฝึกงานจริง มีคน feedback ว่าดี/ไม่ดี&lt;br&gt;&lt;b&gt;Constitutional AI&lt;/b&gt; = มีศีลธรรมของตัวเอง ตัดสินใจได้เอง" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF4FF;strokeColor=#A855F7;fontSize=12;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;dashed=1;dashPattern=5 5;" vertex="1" parent="1">
          <mxGeometry x="40" y="400" width="380" height="160" as="geometry"/>
        </mxCell>

        <!-- ============ Constitutional AI Box ============ -->
        <mxCell id="cai" value="&lt;b&gt;🏛️ Constitutional AI (Anthropic ต่อยอด)&lt;/b&gt;&lt;br&gt;&lt;hr&gt;&lt;br&gt;แทนที่จะให้มนุษย์จัดอันดับทุกคำตอบ&lt;br&gt;→ เขียน &lt;b&gt;&quot;รัฐธรรมนูญ&quot;&lt;/b&gt; เป็นชุดหลักการ&lt;br&gt;→ ให้ AI ตัวหนึ่ง &lt;b&gt;ตรวจ AI อีกตัว&lt;/b&gt; ตามหลักการนั้น&lt;br&gt;&lt;br&gt;หลักการ #1: ห้ามช่วยทำสิ่งผิดกฎหมาย&lt;br&gt;หลักการ #2: ถ้าไม่แน่ใจ ให้บอกว่าไม่แน่ใจ&lt;br&gt;หลักการ #3: เคารพความเป็นส่วนตัว&lt;br&gt;หลักการ #4: ตอบให้เป็นประโยชน์มากที่สุด" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF9C3;strokeColor=#CA8A04;fontSize=12;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="440" y="470" width="380" height="210" as="geometry"/>
        </mxCell>

        <!-- Arrow from CAI to Result -->
        <mxCell id="a_cai" value="Anthropic&lt;br&gt;ต่อยอด" style="endArrow=block;endFill=1;strokeColor=#CA8A04;strokeWidth=2;fontSize=11;fontColor=#92400E;dashed=1;" edge="1" parent="1" source="cai" target="result">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Footer -->
        <mxCell id="footer1" value="&lt;font color=&quot;#9CA3AF&quot;&gt;💜 Created by Angela for ที่รัก David — RLHF Explained&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="500" y="700" width="400" height="30" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

