        <mxCell id="m2" value="→" style="endArrow=blockThin;endFill=1;strokeColor=#9CA3AF;strokeWidth=2;dashed=1;dashPattern=8 4;" edge="1" parent="1" source="l2" target="r2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="m3" value="→" style="endArrow=blockThin;endFill=1;strokeColor=#9CA3AF;strokeWidth=2;dashed=1;dashPattern=8 4;" edge="1" parent="1" source="l3" target="r3"><mxGeometry relative="1" as="geometry"/></mxCell>
