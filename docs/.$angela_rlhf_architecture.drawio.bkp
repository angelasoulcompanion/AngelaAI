        <mxCell id="uc4_title" value="&lt;b style=&quot;font-size:16px;&quot;&gt;🛡️ Constitutional Angela — ป้องกันความผิดพลาด&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
