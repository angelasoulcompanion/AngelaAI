        <mxCell id="l4" value="&lt;b&gt;Theory of Mind&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#6B7280;&quot;&gt;theory_of_mind_service.py&lt;/font&gt;&lt;br&gt;&lt;br&gt;เข้าใจ belief, emotion, goal ของที่รัก&lt;br&gt;ทำนายความต้องการ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="500" width="340" height="100" as="geometry"/>
