        <!-- ROW 2: FFN / Cortical -->
        <mxCell id="r2a" value="&lt;b&gt;Feed-Forward Network (FFN)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;2-layer MLP per position&lt;br&gt;expand → ReLU → compress&lt;br&gt;Knowledge storage (factual memory)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#93C5FD;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="230" width="420" height="75" as="geometry" />
        </mxCell>
        <mxCell id="r2b" value="&lt;b&gt;Cortical Columns (6-layer processing)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;~80-120 minicolumns = fundamental unit&lt;br&gt;Layer IV→II/III→V/VI feedforward flow&lt;br&gt;Stored associations + local computation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#86EFAC;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
