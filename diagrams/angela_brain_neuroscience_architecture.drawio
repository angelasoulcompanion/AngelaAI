        <mxCell id="r2c" value="&lt;b&gt;knowledge_nodes + learnings (PostgreSQL)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;&lt;font color=&quot;#16A34A&quot;&gt;✓&lt;/font&gt; 10,836 knowledge nodes = factual memory&lt;br&gt;&lt;font color=&quot;#16A34A&quot;&gt;✓&lt;/font&gt; Consolidation engine (episodic→semantic)&lt;br&gt;&lt;font color=&quot;#DC2626&quot;&gt;✗&lt;/font&gt; Static storage — ไม่มี dynamic computation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#C4B5FD;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
