        <!-- ROW 1: Attention -->
        <mxCell id="r1a" value="&lt;b&gt;Self-Attention (Q·K·V)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;แต่ละ token ดู relevance กับ&lt;br&gt;ทุก token อื่น → weighted sum&lt;br&gt;Multi-head = หลาย perspective&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#93C5FD;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="130" width="420" height="85" as="geometry" />
        </mxCell>
        <mxCell id="r1b" value="&lt;b&gt;Selective Attention (Thalamus + PFC)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;Thalamus = gate (ข้อมูลไหนผ่าน)&lt;br&gt;PFC = top-down control (จะดูอะไร)&lt;br&gt;Tripartite synapse (Astrocyte) = Q·K·V&lt;br&gt;&lt;b&gt;DAN&lt;/b&gt; (goal-directed) + &lt;b&gt;VAN&lt;/b&gt; (stimulus-driven)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#86EFAC;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="490" y="130" width="420" height="85" as="geometry" />
