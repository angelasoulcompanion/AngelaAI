        <mxCell id="r3c" value="&lt;b&gt;CognitiveEngine 6-phase cycle&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;&lt;font color=&quot;#16A34A&quot;&gt;✓&lt;/font&gt; PERCEIVE→ACTIVATE→SITUATE→DECIDE→EXPRESS→LEARN&lt;br&gt;&lt;font color=&quot;#DC2626&quot;&gt;✗&lt;/font&gt; &lt;b&gt;Feedforward only&lt;/b&gt; — ไม่มี feedback loop กลับไป&lt;br&gt;&lt;font color=&quot;#DC2626&quot;&gt;✗&lt;/font&gt; ไม่มี recurrent processing (สมองมี massive recurrence)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#C4B5FD;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="940" y="320" width="440" height="75" as="geometry" />
