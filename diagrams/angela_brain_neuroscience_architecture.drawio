        <mxCell id="L4_dmn" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;DMN / Spontaneous Thought&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Mind wandering · Daydreaming&lt;br&gt;🆕 Associative chaining (not random)&lt;br&gt;🆕 DMN↔ECN switching for creativity&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#374151;strokeColor=#86EFAC;fontSize=10;" vertex="1" parent="1">
