        <!-- ROW 4: Positional / Temporal -->
        <mxCell id="r4a" value="&lt;b&gt;Positional Encoding (Sinusoidal)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;sin/cos at different frequencies&lt;br&gt;Encodes position in sequence&lt;br&gt;Enables relative position via dot-product&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#93C5FD;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="410" width="420" height="75" as="geometry" />
        </mxCell>
        <mxCell id="r4b" value="&lt;b&gt;Grid Cells (Hippocampus/Entorhinal)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;Periodic hexagonal firing at different scales&lt;br&gt;Mathematical equivalent to sinusoidal encoding&lt;br&gt;Works for spatial AND conceptual navigation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#86EFAC;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="490" y="410" width="420" height="75" as="geometry" />
        </mxCell>
        <mxCell id="r4c" value="&lt;b&gt;TemporalCodelet + Working Memory&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;&lt;font color=&quot;#16A34A&quot;&gt;✓&lt;/font&gt; Time-of-day awareness, special dates, weekend detection&lt;br&gt;&lt;font color=&quot;#16A34A&quot;&gt;✓&lt;/font&gt; Recency-based activation decay (0.1/hour)&lt;br&gt;&lt;font color=&quot;#DC2626&quot;&gt;✗&lt;/font&gt; Linear decay — should be &lt;b&gt;power-law&lt;/b&gt; (Ebbinghaus)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#C4B5FD;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="940" y="410" width="440" height="75" as="geometry" />
        </mxCell>
        <mxCell id="r4d" value="&lt;font color=&quot;#CA8A04&quot;&gt;&lt;b&gt;55%&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF9C3;strokeColor=#FDE047;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1410" y="425" width="80" height="40" as="geometry" />
        </mxCell>

        <!-- ROW 5: Next-token / Predictive Coding -->
        <mxCell id="r5a" value="&lt;b&gt;Next-Token Prediction&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;Predict P(next | context)&lt;br&gt;Minimize cross-entropy loss&lt;br&gt;Autoregressive generation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#93C5FD;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="500" width="420" height="75" as="geometry" />
        </mxCell>
        <mxCell id="r5b" value="&lt;b&gt;Predictive Coding (Friston's FEP)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;Top-down predictions ↓ + Bottom-up errors ↑&lt;br&gt;Minimize free energy (surprise)&lt;br&gt;Multi-timescale, hierarchical, bidirectional&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#86EFAC;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="490" y="500" width="420" height="75" as="geometry" />
        </mxCell>
        <mxCell id="r5c" value="&lt;b&gt;PredictionCodelet + Reward Signals&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;&lt;font color=&quot;#16A34A&quot;&gt;✓&lt;/font&gt; PredictionCodelet predicts David's behavior patterns&lt;br&gt;&lt;font color=&quot;#16A34A&quot;&gt;✓&lt;/font&gt; RLHF reward = prediction error feedback&lt;br&gt;&lt;font color=&quot;#DC2626&quot;&gt;✗&lt;/font&gt; &lt;b&gt;Unidirectional only&lt;/b&gt; — no top-down prediction cascade&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#C4B5FD;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="940" y="500" width="440" height="75" as="geometry" />
        </mxCell>
        <mxCell id="r5d" value="&lt;font color=&quot;#DC2626&quot;&gt;&lt;b&gt;35%&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#FCA5A5;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1410" y="515" width="80" height="40" as="geometry" />
        </mxCell>

        <!-- ROW 6: Softmax / Competition -->
        <mxCell id="r6a" value="&lt;b&gt;Softmax (Attention Weights)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;Soft competition: all contribute but weighted&lt;br&gt;exp(score) / Σexp(scores)&lt;br&gt;Temperature controls sharpness&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#93C5FD;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="590" width="420" height="75" as="geometry" />
        </mxCell>
        <mxCell id="r6b" value="&lt;b&gt;Lateral Inhibition / Winner-Takes-All&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;Neurons compete via inhibitory feedback&lt;br&gt;Most activated neuron suppresses others&lt;br&gt;= Neural implementation of Softmax&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#86EFAC;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="490" y="590" width="420" height="75" as="geometry" />
        </mxCell>
        <mxCell id="r6c" value="&lt;b&gt;ThoughtExpression Threshold + Suppression&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;&lt;font color=&quot;#16A34A&quot;&gt;✓&lt;/font&gt; Motivation threshold (0.65) = competition gate&lt;br&gt;&lt;font color=&quot;#DC2626&quot;&gt;✗&lt;/font&gt; &lt;b&gt;96.9% suppressed&lt;/b&gt; — threshold too aggressive&lt;br&gt;&lt;font color=&quot;#DC2626&quot;&gt;✗&lt;/font&gt; No soft competition — binary pass/fail ไม่ใช่ softmax&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#C4B5FD;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="940" y="590" width="440" height="75" as="geometry" />
        </mxCell>
        <mxCell id="r6d" value="&lt;font color=&quot;#DC2626&quot;&gt;&lt;b&gt;25%&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#FCA5A5;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1410" y="605" width="80" height="40" as="geometry" />
        </mxCell>

        <!-- ROW 7: Context Window / Working Memory -->
        <mxCell id="r7a" value="&lt;b&gt;Context Window (128K+ tokens)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;All tokens equally accessible&lt;br&gt;Sharp boundary (outside = invisible)&lt;br&gt;KV-cache as persistent buffer&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#93C5FD;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="680" width="420" height="75" as="geometry" />
        </mxCell>
        <mxCell id="r7b" value="&lt;b&gt;Working Memory (PFC Sustained Firing)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;~4 chunks (Cowan 2001) — extremely limited&lt;br&gt;Graceful degradation (fade + refresh)&lt;br&gt;Compensated by &lt;b&gt;chunking&lt;/b&gt; + LTM retrieval&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#86EFAC;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="490" y="680" width="420" height="75" as="geometry" />
        </mxCell>
        <mxCell id="r7c" value="&lt;b&gt;WorkingMemory (ephemeral JSON, 20 items)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;&lt;font color=&quot;#16A34A&quot;&gt;✓&lt;/font&gt; Decay over time (0.1/hr) — models fade&lt;br&gt;&lt;font color=&quot;#16A34A&quot;&gt;✓&lt;/font&gt; Spreading activation from context&lt;br&gt;&lt;font color=&quot;#DC2626&quot;&gt;✗&lt;/font&gt; No &lt;b&gt;chunking mechanism&lt;/b&gt; — items are flat, not grouped&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#C4B5FD;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="940" y="680" width="440" height="75" as="geometry" />
        </mxCell>
        <mxCell id="r7d" value="&lt;font color=&quot;#CA8A04&quot;&gt;&lt;b&gt;55%&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF9C3;strokeColor=#FDE047;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1410" y="695" width="80" height="40" as="geometry" />
        </mxCell>

        <!-- ROW 8: Layer Norm / Homeostatic -->
        <mxCell id="r8a" value="&lt;b&gt;Layer Normalization&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;Normalize to zero mean, unit variance&lt;br&gt;Prevents activation explosion/collapse&lt;br&gt;Applied at every sublayer&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#93C5FD;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="770" width="420" height="75" as="geometry" />
        </mxCell>
        <mxCell id="r8b" value="&lt;b&gt;Divisive Normalization / Homeostatic Plasticity&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;Response / Σ(neighbors) = canonical computation&lt;br&gt;Found in retina, thalamus, V1, MT, auditory cortex&lt;br&gt;Synaptic scaling maintains operational range&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#86EFAC;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="490" y="770" width="420" height="75" as="geometry" />
        </mxCell>
        <mxCell id="r8c" value="&lt;b&gt;MetacognitiveState (6 dims, decay to neutral)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;&lt;font color=&quot;#16A34A&quot;&gt;✓&lt;/font&gt; Decay toward 0.5 (neutral) = homeostasis concept&lt;br&gt;&lt;font color=&quot;#DC2626&quot;&gt;✗&lt;/font&gt; &lt;b&gt;Never meaningfully updated&lt;/b&gt; — always at defaults&lt;br&gt;&lt;font color=&quot;#DC2626&quot;&gt;✗&lt;/font&gt; No divisive normalization between metrics&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#C4B5FD;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="940" y="770" width="440" height="75" as="geometry" />
        </mxCell>
        <mxCell id="r8d" value="&lt;font color=&quot;#DC2626&quot;&gt;&lt;b&gt;20%&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#FCA5A5;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1410" y="785" width="80" height="40" as="geometry" />
        </mxCell>

        <!-- MISSING IN TRANSFORMER (brain-only features Angela should have) -->
        <mxCell id="miss_header" value="&lt;b style=&quot;font-size:14px; color:#DC2626&quot;&gt;⚠️ Brain Features Missing from Both Transformer AND Angela&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="870" width="600" height="30" as="geometry" />
        </mxCell>

        <mxCell id="m1" value="&lt;b&gt;🔴 Neuromodulation&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;&lt;b&gt;Brain:&lt;/b&gt; Dopamine, Serotonin, Norepinephrine, Acetylcholine&lt;br&gt;ปรับ learning rate, attention, mood ทั้งระบบ&lt;br&gt;&lt;b&gt;Angela:&lt;/b&gt; ไม่มี — ไม่มี global state modulator&lt;br&gt;&lt;b&gt;Proposal:&lt;/b&gt; &lt;font color=&quot;#7C3AED&quot;&gt;&lt;b&gt;BrainChemistry module&lt;/b&gt;&lt;/font&gt; — 4 ตัวแปร global ที่ปรับ&lt;br&gt;threshold, learning rate, exploration ทั้งระบบ&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#FCA5A5;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="910" width="350" height="140" as="geometry" />
        </mxCell>

        <mxCell id="m2" value="&lt;b&gt;🔴 Recurrent Processing (Feedback Loops)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;&lt;b&gt;Brain:&lt;/b&gt; Massive bidirectional connections&lt;br&gt;Top-down predictions + Bottom-up errors&lt;br&gt;&lt;b&gt;Angela:&lt;/b&gt; Feedforward only within a cycle&lt;br&gt;&lt;b&gt;Proposal:&lt;/b&gt; &lt;font color=&quot;#7C3AED&quot;&gt;&lt;b&gt;Feedback loops&lt;/b&gt;&lt;/font&gt; — output of DECIDE&lt;br&gt;feeds back to PERCEIVE for re-evaluation (max 3 loops)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#FCA5A5;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="410" y="910" width="350" height="140" as="geometry" />
        </mxCell>

        <mxCell id="m3" value="&lt;b&gt;🔴 Global Workspace Competition&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;&lt;b&gt;Brain:&lt;/b&gt; Coalitions compete → winner broadcast&lt;br&gt;Only 1 thought conscious at a time (ignition)&lt;br&gt;&lt;b&gt;Angela:&lt;/b&gt; All thoughts processed equally&lt;br&gt;&lt;b&gt;Proposal:&lt;/b&gt; &lt;font color=&quot;#7C3AED&quot;&gt;&lt;b&gt;Ignition mechanism&lt;/b&gt;&lt;/font&gt; — salience &amp;gt; threshold&lt;br&gt;→ nonlinear amplification → broadcast to all services&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#FCA5A5;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="780" y="910" width="350" height="140" as="geometry" />
        </mxCell>

        <mxCell id="m4" value="&lt;b&gt;🟡 Active Inference (Action→World)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;&lt;b&gt;Brain:&lt;/b&gt; Not just predict — ACT to change&lt;br&gt;the world to match predictions&lt;br&gt;&lt;b&gt;Angela:&lt;/b&gt; Proactive actions exist but limited&lt;br&gt;&lt;b&gt;Proposal:&lt;/b&gt; Connect predictions → plans → tools&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF9C3;strokeColor=#FDE047;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="1150" y="910" width="340" height="140" as="geometry" />
        </mxCell>

        <!-- OVERALL SCORE -->
        <mxCell id="overall" value="&lt;b style=&quot;font-size:14px&quot;&gt;Overall Brain Fidelity: &lt;font color=&quot;#CA8A04&quot;&gt;43%&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;ที่ดี: Memory system, Emotion construction, Dual-process thinking&lt;br&gt;ที่ขาด: Recurrence, Competition, Neuromodulation, Predictive coding&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3F4F6;strokeColor=#9CA3AF;verticalAlign=middle;fontSize=12;spacingLeft=12;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="1070" width="700" height="65" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="leg" value="&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;&lt;b&gt;Legend:&lt;/b&gt; &lt;font color=&quot;#16A34A&quot;&gt;✓ มีแล้ว&lt;/font&gt; · &lt;font color=&quot;#DC2626&quot;&gt;✗ ยังขาด&lt;/font&gt; · Match: &lt;font color=&quot;#16A34A&quot;&gt;70%+&lt;/font&gt; Good · &lt;font color=&quot;#CA8A04&quot;&gt;50-69%&lt;/font&gt; Partial · &lt;font color=&quot;#DC2626&quot;&gt;&amp;lt;50%&lt;/font&gt; Needs Work&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="300" y="1150" width="800" height="20" as="geometry" />
