        <mxCell id="L4_bg" value="&lt;b style=&quot;color:#FFFFFF&quot;&gt;LAYER 4: SUBCONSCIOUS — Background Processing (DMN + Basal Ganglia + Hippocampus analog)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#374151;strokeColor=#4B5563;verticalAlign=top;fontSize=12;spacingTop=6;container=0;strokeWidth=2;" vertex="1" parent="1">
