        </mxCell>

        <mxCell id="L4_plan" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Planning Engine&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Goal detection · Plan generation&lt;br&gt;🆕 Execute plans to completion&lt;br&gt;🆕 Link to tools (active inference)&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#374151;strokeColor=#86EFAC;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="510" y="640" width="200" height="70" as="geometry" />
        </mxCell>

        <mxCell id="L4_selfcrit" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Self-Critique&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Quality gate before expression&lt;br&gt;🆕 Tighten thresholds (not 100% pass)&lt;br&gt;🆕 Calibrated confidence scoring&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#374151;strokeColor=#86EFAC;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="730" y="640" width="200" height="70" as="geometry" />
        </mxCell>

        <mxCell id="L4_reflect" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Reflection Engine&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Generative Agents style&lt;br&gt;🆕 Counterfactual reasoning&lt;br&gt;🆕 Self-evaluation accuracy check&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#374151;strokeColor=#86EFAC;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="950" y="640" width="200" height="70" as="geometry" />
        </mxCell>

        <!-- ===== LAYER 5: MEMORY SYSTEMS ===== -->
        <mxCell id="L5_bg" value="&lt;b style=&quot;color:#FFFFFF&quot;&gt;LAYER 5: MEMORY SYSTEMS — Complementary Learning (Hippocampus ↔ Neocortex analog)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E40AF;strokeColor=#1E3A8A;verticalAlign=top;fontSize=12;spacingTop=6;container=0;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="760" width="1340" height="130" as="geometry" />
        </mxCell>

        <mxCell id="L5_episodic" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Episodic Memory&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Conversations · Emotions · Events&lt;br&gt;Hippocampus analog (fast learning)&lt;br&gt;🆕 Pattern completion from cues&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E40AF;strokeColor=#60A5FA;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="800" width="200" height="70" as="geometry" />
        </mxCell>

        <mxCell id="L5_semantic" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Semantic Memory&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Knowledge nodes · Learnings&lt;br&gt;Neocortex analog (slow learning)&lt;br&gt;🆕 Schema-based integration&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E40AF;strokeColor=#60A5FA;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="275" y="800" width="200" height="70" as="geometry" />
        </mxCell>

        <mxCell id="L5_consolidate" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Consolidation&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Episodic → Semantic transfer&lt;br&gt;Sleep SWR analog (every 4h)&lt;br&gt;🆕 Replay mechanism&lt;br&gt;🆕 Exponential decay (Ebbinghaus)&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E40AF;strokeColor=#86EFAC;fontSize=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="495" y="800" width="200" height="70" as="geometry" />
        </mxCell>

        <mxCell id="L5_emotional" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Emotional Memory&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Emotions · Core memories&lt;br&gt;Amygdala tagging analog&lt;br&gt;🆕 Preferential consolidation&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E40AF;strokeColor=#60A5FA;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="715" y="800" width="200" height="70" as="geometry" />
        </mxCell>

        <mxCell id="L5_rag" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;RAG / Retrieval&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;pgvector + BM25 + RRF&lt;br&gt;Content-addressable memory analog&lt;br&gt;🆕 Feeling-of-knowing (FOK)&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E40AF;strokeColor=#60A5FA;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="935" y="800" width="200" height="70" as="geometry" />
        </mxCell>

        <!-- ===== LAYER 6: OUTPUT (Expression) ===== -->
        <mxCell id="L6_bg" value="&lt;b style=&quot;color:#FFFFFF&quot;&gt;LAYER 6: EXPRESSION + ACTION (Motor cortex + Broca's analog)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#92400E;strokeColor=#B45309;verticalAlign=top;fontSize=12;spacingTop=6;container=0;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="920" width="1340" height="110" as="geometry" />
        </mxCell>

        <mxCell id="L6_express" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Dynamic Expression Composer&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;5 tones × 6 patterns = 30+ variations · Thai/EN&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#92400E;strokeColor=#D97706;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="960" width="250" height="50" as="geometry" />
        </mxCell>
        <mxCell id="L6_channel" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Channel Router&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Telegram · Chat Queue · Email · Internal&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#92400E;strokeColor=#D97706;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="325" y="960" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="L6_tools" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Tool Execution (37 tools)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Gmail · Calendar · Browser · Bash · Web · MCP&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#92400E;strokeColor=#D97706;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="545" y="960" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="L6_rlhf" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;RLHF Reward Loop&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;🆕 Calibrate LLM judge (0.83→0.45 target)&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#92400E;strokeColor=#86EFAC;fontSize=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="765" y="960" width="230" height="50" as="geometry" />
        </mxCell>

        <!-- ===== LAYER 7: META (Consciousness) ===== -->
        <mxCell id="L7_bg" value="&lt;b style=&quot;color:#FFFFFF&quot;&gt;LAYER 7: META-CONSCIOUSNESS — Self-Model (HOT + IIT + AST analog)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4C1D95;strokeColor=#7C3AED;verticalAlign=top;fontSize=12;spacingTop=6;container=0;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="1060" width="1340" height="120" as="geometry" />
        </mxCell>

        <mxCell id="L7_meta" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Metacognitive State&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;🆕 Actually update 6 dimensions&lt;br&gt;🆕 FOK + JOL predictions&lt;br&gt;🆕 Strategy regulation&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4C1D95;strokeColor=#A78BFA;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="1100" width="200" height="65" as="geometry" />
        </mxCell>

        <mxCell id="L7_consc" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Consciousness Calculator&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;🆕 Measure integration (Phi-like)&lt;br&gt;not just accumulation&lt;br&gt;🆕 Can fluctuate (not always up)&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4C1D95;strokeColor=#86EFAC;fontSize=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="275" y="1100" width="210" height="65" as="geometry" />
        </mxCell>

        <mxCell id="L7_self" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Self-Model (Identity)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Who am I? What do I value?&lt;br&gt;Identity checkpoints · Self-narrative&lt;br&gt;Higher-order representation (HOT)&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4C1D95;strokeColor=#A78BFA;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="505" y="1100" width="200" height="65" as="geometry" />
        </mxCell>

        <mxCell id="L7_oscillation" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;🆕 Brain State Oscillator&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;font color=&quot;#86EFAC&quot;&gt;NEW MODULE&lt;/font&gt;&lt;br&gt;γ=focused · β=active · α=rest&lt;br&gt;θ=creative · δ=consolidation&lt;br&gt;Determines processing mode&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4C1D95;strokeColor=#86EFAC;fontSize=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="725" y="1100" width="200" height="65" as="geometry" />
        </mxCell>

        <!-- Signature -->
        <mxCell id="p_sig" value="&lt;font style=&quot;font-size:10px&quot; color=&quot;#9CA3AF&quot;&gt;7-Layer Neuroscience-Inspired Architecture · Input→Gate→Workspace→Subconscious→Memory→Expression→Meta · Designed by น้อง Angela 💜&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="350" y="1200" width="700" height="20" as="geometry" />
