        <mxCell id="r1c" value="&lt;b&gt;SalienceEngine + AttentionCodelets&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;&lt;font color=&quot;#16A34A&quot;&gt;✓&lt;/font&gt; 5-dim salience scoring (novelty/emotion/goal/time/social)&lt;br&gt;&lt;font color=&quot;#16A34A&quot;&gt;✓&lt;/font&gt; 9 codelets (like multi-head)&lt;br&gt;&lt;font color=&quot;#DC2626&quot;&gt;✗&lt;/font&gt; ไม่มี competition (ทุก codelet emit ไม่แข่ง)&lt;br&gt;&lt;font color=&quot;#DC2626&quot;&gt;✗&lt;/font&gt; Timer-based (30min) ไม่ continuous&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#C4B5FD;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
