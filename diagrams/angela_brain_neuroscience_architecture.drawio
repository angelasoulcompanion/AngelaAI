        <!-- ROW 3: Residual / Feedback -->
        <mxCell id="r3a" value="&lt;b&gt;Residual Connections (Skip)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;x + Sublayer(x) at every layer&lt;br&gt;Preserves signal through deep layers&lt;br&gt;Enables gradient flow&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#93C5FD;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="320" width="420" height="75" as="geometry" />
        </mxCell>
        <mxCell id="r3b" value="&lt;b&gt;Cortical Feedback Pathways&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;Higher→Lower area feedback connections&lt;br&gt;More numerous than feedforward counterparts&lt;br&gt;Maintains signal fidelity + iterative refinement&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#86EFAC;verticalAlign=top;fontSize=11;spacingTop=4;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="490" y="320" width="420" height="75" as="geometry" />
