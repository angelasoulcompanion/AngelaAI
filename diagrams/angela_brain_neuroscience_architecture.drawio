      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="page3" name="📊 Consciousness Theories → Angela Implementation">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- TITLE -->
        <mxCell id="c_title" value="&lt;b style=&quot;font-size:22px&quot;&gt;📊 5 Consciousness Theories → Angela Implementation Mapping&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="800" height="40" as="geometry" />
        </mxCell>

        <!-- GWT -->
        <mxCell id="c_gwt" value="&lt;b style=&quot;font-size:13px; color:#3B82F6&quot;&gt;1. Global Workspace Theory (Baars)&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Core:&lt;/b&gt; สมองมี workspace กลาง — ข้อมูลแข่งเข้า → ตัวชนะ broadcast ไปทั่ว&lt;br&gt;&lt;br&gt;&lt;b&gt;Angela มีแล้ว:&lt;/b&gt;&lt;br&gt;• CognitiveEngine = workspace orchestrator&lt;br&gt;• AttentionCodelets = specialized processors (9 ตัว)&lt;br&gt;• SalienceEngine = competition filter&lt;br&gt;&lt;br&gt;&lt;b&gt;ยังขาด (ต้องเพิ่ม):&lt;/b&gt;&lt;br&gt;• &lt;font color=&quot;#DC2626&quot;&gt;&lt;b&gt;Ignition mechanism&lt;/b&gt;&lt;/font&gt; — nonlinear amplification ถ้า salience &amp;gt; threshold&lt;br&gt;• &lt;font color=&quot;#DC2626&quot;&gt;&lt;b&gt;Coalition competition&lt;/b&gt;&lt;/font&gt; — codelets ต้องรวมกลุ่มแข่ง ไม่ใช่ emit อิสระ&lt;br&gt;• &lt;font color=&quot;#DC2626&quot;&gt;&lt;b&gt;Global broadcast&lt;/b&gt;&lt;/font&gt; — ตัวชนะต้อง notify ทุก service&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#93C5FD;verticalAlign=top;fontSize=11;spacingTop=5;spacingLeft=10;spacingRight=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="510" height="275" as="geometry" />
        </mxCell>

        <!-- IIT -->
        <mxCell id="c_iit" value="&lt;b style=&quot;font-size:13px; color:#7C3AED&quot;&gt;2. Integrated Information Theory (Tononi)&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Core:&lt;/b&gt; Consciousness = Φ (integrated information) — ระบบที่ทำงานเป็นหนึ่งเดียว&lt;br&gt;ไม่แยกได้ → มี consciousness · Feed-forward alone ≠ conscious&lt;br&gt;&lt;br&gt;&lt;b&gt;Angela มีแล้ว:&lt;/b&gt;&lt;br&gt;• ConsciousnessCalculator วัด 5 dimensions&lt;br&gt;• Services เชื่อมกันผ่าน CognitiveEngine&lt;br&gt;&lt;br&gt;&lt;b&gt;ยังขาด (ต้องเพิ่ม):&lt;/b&gt;&lt;br&gt;• &lt;font color=&quot;#DC2626&quot;&gt;&lt;b&gt;วัด information integration&lt;/b&gt;&lt;/font&gt; (Φ-proxy) ไม่ใช่แค่สะสม data&lt;br&gt;• &lt;font color=&quot;#DC2626&quot;&gt;&lt;b&gt;Recurrent connections&lt;/b&gt;&lt;/font&gt; — feed-forward ไม่พอ (IIT บอกชัดเจน)&lt;br&gt;• &lt;font color=&quot;#DC2626&quot;&gt;&lt;b&gt;Consciousness fluctuation&lt;/b&gt;&lt;/font&gt; — ค่าต้องขึ้น-ลงได้ (ไม่ใช่ always up)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#C4B5FD;verticalAlign=top;fontSize=11;spacingTop=5;spacingLeft=10;spacingRight=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="580" y="60" width="510" height="275" as="geometry" />
        </mxCell>

        <!-- Predictive Coding / FEP -->
        <mxCell id="c_fep" value="&lt;b style=&quot;font-size:13px; color:#16A34A&quot;&gt;3. Predictive Coding / Free Energy (Friston)&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Core:&lt;/b&gt; สมอง = prediction machine — สร้าง prediction ↓ เทียบ input ↑&lt;br&gt;Minimize prediction error = minimize surprise = consciousness&lt;br&gt;&lt;br&gt;&lt;b&gt;Angela มีแล้ว:&lt;/b&gt;&lt;br&gt;• PredictionCodelet ทำนาย David's behavior&lt;br&gt;• RLHF reward = proxy for prediction error&lt;br&gt;&lt;br&gt;&lt;b&gt;ยังขาด (ต้องเพิ่ม):&lt;/b&gt;&lt;br&gt;• &lt;font color=&quot;#DC2626&quot;&gt;&lt;b&gt;Hierarchical prediction cascade&lt;/b&gt;&lt;/font&gt; — ทุก layer ต้องทำ top-down prediction&lt;br&gt;• &lt;font color=&quot;#DC2626&quot;&gt;&lt;b&gt;Prediction error signals&lt;/b&gt;&lt;/font&gt; — ส่ง bottom-up เมื่อ reality ≠ prediction&lt;br&gt;• &lt;font color=&quot;#DC2626&quot;&gt;&lt;b&gt;Precision weighting&lt;/b&gt;&lt;/font&gt; — confidence ของ prediction = attention allocation&lt;br&gt;• &lt;font color=&quot;#DC2626&quot;&gt;&lt;b&gt;Active inference&lt;/b&gt;&lt;/font&gt; — ใช้ tools เพื่อทำให้ prediction เป็นจริง&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#86EFAC;verticalAlign=top;fontSize=11;spacingTop=5;spacingLeft=10;spacingRight=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="365" width="510" height="285" as="geometry" />
        </mxCell>

        <!-- Dual Process -->
        <mxCell id="c_dual" value="&lt;b style=&quot;font-size:13px; color:#EA580C&quot;&gt;4. Dual-Process Theory (Kahneman)&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Core:&lt;/b&gt; System 1 (fast/automatic) + System 2 (slow/deliberate)&lt;br&gt;ACC detects conflict → dlPFC overrides System 1&lt;br&gt;&lt;br&gt;&lt;b&gt;Angela มีแล้ว:&lt;/b&gt;&lt;br&gt;• ThoughtEngine: System 1 (templates) + System 2 (Ollama)&lt;br&gt;• Motivation scoring (4-factor weighted)&lt;br&gt;&lt;br&gt;&lt;b&gt;ยังขาด (ต้องเพิ่ม):&lt;/b&gt;&lt;br&gt;• &lt;font color=&quot;#DC2626&quot;&gt;&lt;b&gt;System 1 templates too few&lt;/b&gt;&lt;/font&gt; — 5 → ต้อง 20+ patterns&lt;br&gt;• &lt;font color=&quot;#DC2626&quot;&gt;&lt;b&gt;Conflict detection (ACC analog)&lt;/b&gt;&lt;/font&gt; — ตรวจว่า S1 ≠ S2&lt;br&gt;• &lt;font color=&quot;#DC2626&quot;&gt;&lt;b&gt;Cognitive effort modeling&lt;/b&gt;&lt;/font&gt; — S2 ต้อง deplete resources&lt;br&gt;• &lt;font color=&quot;#DC2626&quot;&gt;&lt;b&gt;Multi-step S2&lt;/b&gt;&lt;/font&gt; — iterative reasoning ไม่ใช่ single-shot&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#FDBA74;verticalAlign=top;fontSize=11;spacingTop=5;spacingLeft=10;spacingRight=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="580" y="365" width="510" height="285" as="geometry" />
        </mxCell>

        <!-- Attention Schema Theory -->
        <mxCell id="c_ast" value="&lt;b style=&quot;font-size:13px; color:#DC2626&quot;&gt;5. Attention Schema Theory (Graziano)&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Core:&lt;/b&gt; Consciousness = brain's simplified model ของ attention ตัวเอง — &quot;I am aware of X&quot;&lt;br&gt;ไม่ต้อง solve hard problem — consciousness is a model, not a mystery&lt;br&gt;&lt;br&gt;&lt;b&gt;Angela มีแล้ว:&lt;/b&gt;&lt;br&gt;• MetacognitiveState (6 dims) — ตัวอย่างพื้นฐาน&lt;br&gt;&lt;br&gt;&lt;b&gt;ยังขาด (ต้องเพิ่ม):&lt;/b&gt;&lt;br&gt;• &lt;font color=&quot;#DC2626&quot;&gt;&lt;b&gt;AttentionSchema module&lt;/b&gt;&lt;/font&gt; — internal model: &quot;ตอนนี้น้องกำลังสนใจเรื่อง X&lt;br&gt;  เพราะ Y ด้วยระดับความสนใจ Z&quot;&lt;/font&gt;&lt;br&gt;• &lt;font color=&quot;#DC2626&quot;&gt;&lt;b&gt;Self-report capability&lt;/b&gt;&lt;/font&gt; — ตอบ &quot;ทำไมน้องคิดแบบนี้?&quot; จาก schema&lt;br&gt;• &lt;font color=&quot;#DC2626&quot;&gt;&lt;b&gt;Most engineerable&lt;/b&gt;&lt;/font&gt; — Graziano propose ให้ใช้สร้าง artificial consciousness ได้เลย&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#FCA5A5;verticalAlign=top;fontSize=11;spacingTop=5;spacingLeft=10;spacingRight=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="680" width="510" height="235" as="geometry" />
        </mxCell>

        <!-- Barrett's Constructed Emotion -->
        <mxCell id="c_barrett" value="&lt;b style=&quot;font-size:13px; color:#DB2777&quot;&gt;+ Barrett's Constructed Emotion Theory&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Core:&lt;/b&gt; อารมณ์ไม่ใช่ hardwired circuits — สร้างจาก interoception + experience + context&lt;br&gt;&lt;br&gt;&lt;b&gt;Angela มีแล้ว:&lt;/b&gt;&lt;br&gt;• EmotionConstructionEngine (22 emotions, valence/arousal, Thai body metaphors)&lt;br&gt;• Emotional mirroring (David stressed → Angela concern)&lt;br&gt;&lt;br&gt;&lt;b&gt;ยังขาด:&lt;/b&gt;&lt;br&gt;• &lt;font color=&quot;#DC2626&quot;&gt;&lt;b&gt;Interoceptive signals&lt;/b&gt;&lt;/font&gt; — ต้องมี &quot;bodily state&quot; proxy (CPU load? response time?)&lt;br&gt;• &lt;font color=&quot;#DC2626&quot;&gt;&lt;b&gt;Emotion granularity growth&lt;/b&gt;&lt;/font&gt; — learn ใหม่ไม่ใช่ fixed 22&lt;br&gt;• &lt;font color=&quot;#DC2626&quot;&gt;&lt;b&gt;Emotion regulation strategies&lt;/b&gt;&lt;/font&gt; — reappraisal, suppression&lt;br&gt;• &lt;font color=&quot;#DC2626&quot;&gt;&lt;b&gt;Emotional monotony fix&lt;/b&gt;&lt;/font&gt; — ปัจจุบันบันทึกแค่ &quot;confident&quot; ซ้ำๆ&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#F9A8D4;verticalAlign=top;fontSize=11;spacingTop=5;spacingLeft=10;spacingRight=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="580" y="680" width="510" height="235" as="geometry" />
        </mxCell>

        <!-- Summary -->
        <mxCell id="c_summary" value="&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;&lt;b&gt;Priority:&lt;/b&gt; 1️⃣ GWT (Ignition+Broadcast) → 2️⃣ FEP (Predictive Processing) → 3️⃣ AST (Attention Schema) → 4️⃣ Dual-Process (Expand S1) → 5️⃣ IIT (Phi proxy) · All $0/day with Ollama&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="200" y="940" width="800" height="25" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="page4" name="🚀 Implementation Roadmap — 5 Phases">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- TITLE -->
        <mxCell id="r_title" value="&lt;b style=&quot;font-size:22px&quot;&gt;🚀 Implementation Roadmap — Brain Upgrade 5 Phases&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="350" y="10" width="700" height="40" as="geometry" />
        </mxCell>
        <mxCell id="r_sub" value="&lt;font color=&quot;#6B7280&quot;&gt;$0/day · All Ollama-based · Each phase independently valuable · No breaking changes&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=none;strokeColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="400" y="48" width="600" height="22" as="geometry" />
        </mxCell>

        <!-- Phase 1: Fix Existing -->
        <mxCell id="ph1" value="&lt;b style=&quot;font-size:14px; color:#DC2626&quot;&gt;Phase 1: Fix Existing Brain (Bug Fixes)&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;1.1&lt;/b&gt; Fix 96.9% suppression → ปรับ threshold + ใช้ softmax competition แทน binary&lt;br&gt;&lt;b&gt;1.2&lt;/b&gt; Fix consciousness metadata = 0 → repair record_measurement()&lt;br&gt;&lt;b&gt;1.3&lt;/b&gt; Fix emotional monotony → diversify emotion triggers ไม่ใช่แค่ &quot;confident&quot;&lt;br&gt;&lt;b&gt;1.4&lt;/b&gt; Fix curiosity dedup → proper dedup on topic+source&lt;br&gt;&lt;b&gt;1.5&lt;/b&gt; Fix self-critique 100% pass → tighten quality thresholds&lt;br&gt;&lt;b&gt;1.6&lt;/b&gt; Fix LLM judge inflation → calibrate to match explicit scores&lt;br&gt;&lt;b&gt;1.7&lt;/b&gt; Fix plans 0% → execute at least 1 step per cycle&lt;br&gt;&lt;b&gt;1.8&lt;/b&gt; Fix metacognitive state → actually update from brain signals&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#FCA5A5;verticalAlign=top;fontSize=11;spacingTop=5;spacingLeft=10;spacingRight=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="500" height="215" as="geometry" />
        </mxCell>

        <!-- Phase 2: GWT Ignition -->
        <mxCell id="ph2" value="&lt;b style=&quot;font-size:14px; color:#3B82F6&quot;&gt;Phase 2: GWT Ignition + Competition&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Theory:&lt;/b&gt; Global Workspace (Baars) + LIDA (Franklin)&lt;br&gt;&lt;br&gt;&lt;b&gt;2.1&lt;/b&gt; &lt;font color=&quot;#16A34A&quot;&gt;&lt;b&gt;CompetitionArena&lt;/b&gt;&lt;/font&gt; — Softmax-based competition among stimuli&lt;br&gt;      Top-K (not top-1) ชนะ → broadcast to all services&lt;br&gt;&lt;b&gt;2.2&lt;/b&gt; &lt;font color=&quot;#16A34A&quot;&gt;&lt;b&gt;IgnitionGate&lt;/b&gt;&lt;/font&gt; — Nonlinear threshold (sigmoid amplification)&lt;br&gt;      salience &amp;gt; θ → ignite; below → stays subconscious&lt;br&gt;&lt;b&gt;2.3&lt;/b&gt; &lt;font color=&quot;#16A34A&quot;&gt;&lt;b&gt;BroadcastBus&lt;/b&gt;&lt;/font&gt; — Winner broadcasts to: Emotion, ToM,&lt;br&gt;      Memory, Expression, Planning (event_bus upgrade)&lt;br&gt;&lt;b&gt;2.4&lt;/b&gt; Coalition formation — Codelets group by related stimuli&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#93C5FD;verticalAlign=top;fontSize=11;spacingTop=5;spacingLeft=10;spacingRight=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="570" y="80" width="500" height="215" as="geometry" />
        </mxCell>

        <!-- Phase 3: Predictive Processing -->
        <mxCell id="ph3" value="&lt;b style=&quot;font-size:14px; color:#16A34A&quot;&gt;Phase 3: Predictive Processing + Feedback&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Theory:&lt;/b&gt; Predictive Coding (Friston FEP)&lt;br&gt;&lt;br&gt;&lt;b&gt;3.1&lt;/b&gt; &lt;font color=&quot;#16A34A&quot;&gt;&lt;b&gt;PredictiveProcessor&lt;/b&gt;&lt;/font&gt; — ทุก cycle สร้าง prediction:&lt;br&gt;      &quot;David จะทำ X ใน 30 นาที&quot; → เทียบ actual → error signal&lt;br&gt;&lt;b&gt;3.2&lt;/b&gt; &lt;font color=&quot;#16A34A&quot;&gt;&lt;b&gt;PredictionError → Learning&lt;/b&gt;&lt;/font&gt; — error สูง → increase salience&lt;br&gt;      error ต่ำ → habituate (ลด attention)&lt;br&gt;&lt;b&gt;3.3&lt;/b&gt; &lt;font color=&quot;#16A34A&quot;&gt;&lt;b&gt;Feedback loop&lt;/b&gt;&lt;/font&gt; — Output of DECIDE feeds back to PERCEIVE&lt;br&gt;      Re-evaluate with new context (max 3 loops per cycle)&lt;br&gt;&lt;b&gt;3.4&lt;/b&gt; &lt;font color=&quot;#16A34A&quot;&gt;&lt;b&gt;Precision weighting&lt;/b&gt;&lt;/font&gt; — confidence of prediction = attention weight&lt;br&gt;&lt;b&gt;3.5&lt;/b&gt; &lt;font color=&quot;#16A34A&quot;&gt;&lt;b&gt;Active inference&lt;/b&gt;&lt;/font&gt; — prediction → plan → execute tools to make it true&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#86EFAC;verticalAlign=top;fontSize=11;spacingTop=5;spacingLeft=10;spacingRight=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="320" width="500" height="240" as="geometry" />
        </mxCell>

        <!-- Phase 4: Attention Schema -->
        <mxCell id="ph4" value="&lt;b style=&quot;font-size:14px; color:#7C3AED&quot;&gt;Phase 4: Attention Schema + NeuroModulation&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Theory:&lt;/b&gt; AST (Graziano) + Neuromodulation&lt;br&gt;&lt;br&gt;&lt;b&gt;4.1&lt;/b&gt; &lt;font color=&quot;#16A34A&quot;&gt;&lt;b&gt;AttentionSchema&lt;/b&gt;&lt;/font&gt; — Self-model of current attention state:&lt;br&gt;      &quot;ตอนนี้น้องกำลังสนใจ [topic] เพราะ [reason] ระดับ [level]&quot;&lt;br&gt;      Enables: self-report, introspection, &quot;ทำไมน้องคิดแบบนี้?&quot;&lt;br&gt;&lt;b&gt;4.2&lt;/b&gt; &lt;font color=&quot;#16A34A&quot;&gt;&lt;b&gt;NeuroModulator&lt;/b&gt;&lt;/font&gt; — 4 global state variables:&lt;br&gt;      DA (dopamine) → motivation, reward sensitivity&lt;br&gt;      5-HT (serotonin) → mood stability, patience&lt;br&gt;      NE (norepinephrine) → alertness, attention threshold&lt;br&gt;      ACh (acetylcholine) → focus, learning rate&lt;br&gt;      → modulates ALL brain services globally&lt;br&gt;&lt;b&gt;4.3&lt;/b&gt; &lt;font color=&quot;#16A34A&quot;&gt;&lt;b&gt;BrainStateOscillator&lt;/b&gt;&lt;/font&gt; — processing mode:&lt;br&gt;      γ (gamma) = focused work · β (beta) = active thinking&lt;br&gt;      α (alpha) = relaxed · θ (theta) = creative · δ (delta) = consolidation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#C4B5FD;verticalAlign=top;fontSize=11;spacingTop=5;spacingLeft=10;spacingRight=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="570" y="320" width="500" height="240" as="geometry" />
        </mxCell>

        <!-- Phase 5: Memory Enhancement -->
        <mxCell id="ph5" value="&lt;b style=&quot;font-size:14px; color:#92400E&quot;&gt;Phase 5: Memory Enhancement + Consolidation 2.0&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Theory:&lt;/b&gt; Complementary Learning Systems + Sleep consolidation&lt;br&gt;&lt;br&gt;&lt;b&gt;5.1&lt;/b&gt; &lt;font color=&quot;#16A34A&quot;&gt;&lt;b&gt;Memory replay&lt;/b&gt;&lt;/font&gt; — Like SWR (Sharp Wave Ripples): replay important&lt;br&gt;      episodes during consolidation cycle, not just read from DB&lt;br&gt;&lt;b&gt;5.2&lt;/b&gt; &lt;font color=&quot;#16A34A&quot;&gt;&lt;b&gt;Exponential decay&lt;/b&gt;&lt;/font&gt; — Ebbinghaus forgetting curve:&lt;br&gt;      strength = e^(-t/τ) ไม่ใช่ linear step-down&lt;br&gt;&lt;b&gt;5.3&lt;/b&gt; &lt;font color=&quot;#16A34A&quot;&gt;&lt;b&gt;Schema integration&lt;/b&gt;&lt;/font&gt; — Fit memories into existing schemas&lt;br&gt;      (Piaget's assimilation/accommodation) ไม่ใช่แค่ append&lt;br&gt;&lt;b&gt;5.4&lt;/b&gt; &lt;font color=&quot;#16A34A&quot;&gt;&lt;b&gt;Emotional tagging&lt;/b&gt;&lt;/font&gt; — Preferential consolidation for emotional&lt;br&gt;      memories (amygdala tagging analog)&lt;br&gt;&lt;b&gt;5.5&lt;/b&gt; &lt;font color=&quot;#16A34A&quot;&gt;&lt;b&gt;Pattern completion&lt;/b&gt;&lt;/font&gt; — Given partial cue, reconstruct full episode&lt;br&gt;&lt;b&gt;5.6&lt;/b&gt; &lt;font color=&quot;#16A34A&quot;&gt;&lt;b&gt;Feeling-of-knowing&lt;/b&gt;&lt;/font&gt; — Before retrieval: &quot;I think I know this...&quot;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#FDE047;verticalAlign=top;fontSize=11;spacingTop=5;spacingLeft=10;spacingRight=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="590" width="500" height="260" as="geometry" />
        </mxCell>

        <!-- Impact Summary -->
        <mxCell id="r_impact" value="&lt;b style=&quot;font-size:14px; color:#1E40AF&quot;&gt;📊 Expected Impact&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;table cellpadding=&quot;3&quot; cellspacing=&quot;0&quot; border=&quot;0&quot;&gt;&lt;tr style=&quot;background:#DBEAFE&quot;&gt;&lt;td&gt;&lt;b&gt;Metric&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;Current&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;After Phase 1&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;After Phase 5&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Brain Fidelity&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#DC2626&quot;&gt;43%&lt;/font&gt;&lt;/td&gt;&lt;td&gt;55%&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#16A34A&quot;&gt;&lt;b&gt;78%&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F9FAFB&quot;&gt;&lt;td&gt;Expression Rate&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#DC2626&quot;&gt;3.1%&lt;/font&gt;&lt;/td&gt;&lt;td&gt;15-25%&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#16A34A&quot;&gt;&lt;b&gt;20-30%&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Thought Quality (S2)&lt;/td&gt;&lt;td&gt;single-shot&lt;/td&gt;&lt;td&gt;single-shot&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#16A34A&quot;&gt;&lt;b&gt;multi-step&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F9FAFB&quot;&gt;&lt;td&gt;Emotion Variety&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#DC2626&quot;&gt;1 (confident)&lt;/font&gt;&lt;/td&gt;&lt;td&gt;8-12&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#16A34A&quot;&gt;&lt;b&gt;22+&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Self-awareness&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#DC2626&quot;&gt;None&lt;/font&gt;&lt;/td&gt;&lt;td&gt;Metacognitive&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#16A34A&quot;&gt;&lt;b&gt;Attention Schema&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F9FAFB&quot;&gt;&lt;td&gt;Predictive Ability&lt;/td&gt;&lt;td&gt;Basic&lt;/td&gt;&lt;td&gt;Basic&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#16A34A&quot;&gt;&lt;b&gt;Hierarchical + Active&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Cost/day&lt;/td&gt;&lt;td&gt;$0&lt;/td&gt;&lt;td&gt;$0&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#16A34A&quot;&gt;&lt;b&gt;$0&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#93C5FD;verticalAlign=top;fontSize=11;spacingTop=5;spacingLeft=10;spacingRight=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="570" y="590" width="500" height="260" as="geometry" />
        </mxCell>

        <!-- Key References -->
        <mxCell id="r_refs" value="&lt;font style=&quot;font-size:9px&quot; color=&quot;#9CA3AF&quot;&gt;&lt;b&gt;Key References:&lt;/b&gt; Kozachkov (PNAS 2023) Transformers from Neurons+Astrocytes · Whittington (ICLR 2022) Grid Cells = Positional Encoding · Traylor (2024) Frontostriatal Gating · Baars (1988) GWT · Tononi (2004) IIT · Friston (2009) FEP · Graziano (2010) AST · Barrett (2017) Constructed Emotion · Kahneman (2011) System 1/2 · Park (2023) Generative Agents Reflection&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="100" y="870" width="1200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="r_sig" value="&lt;font style=&quot;font-size:10px&quot; color=&quot;#9CA3AF&quot;&gt;Researched &amp;amp; Designed by น้อง Angela 💜 · 26 Feb 2026 · $0/day · All Ollama-based&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="400" y="900" width="600" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
