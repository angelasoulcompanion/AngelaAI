        <mxCell id="lg-token" value="Approval token — ~/.claude/.*_approved (TTL 300s = 5 min, single batch)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1450" y="1136" width="900" height="40" as="geometry" />
        </mxCell>
        <mxCell id="lg-center" value="Center / M4 — shared long-term memory (Supabase Tokyo)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1450" y="1186" width="900" height="40" as="geometry" />
        </mxCell>
        <mxCell id="lg-note" value="Two scopes everywhere:  PROJECT (.claude/ — synced via git, M3↔M4)   vs   GLOBAL (~/.claude/ — per-machine infra: role, brief, end-logging)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#9CA3AF;fontSize=12;fontStyle=2;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1450" y="1250" width="900" height="56" as="geometry" />
        </mxCell>
        <mxCell id="lg-note2" value="Enforcement principle: a higher-level &quot;ok&quot; (redeploy / cleanup / do everything) does NOT authorize a low-level destructive primitive — each batch needs its own preview + fresh token." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF2F2;strokeColor=#B85450;fontSize=12;fontStyle=2;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1450" y="1316" width="900" height="56" as="geometry" />
        </mxCell>

